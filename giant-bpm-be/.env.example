# Database URL (local development)
DATABASE_URL="postgresql://postgres:password@localhost:5432/bpm-local-db"
PUBLIC_ID_PREFIX=L

# Feature flags (default disabled in production; enabled for local dev/e2e)
# Set to 'true' to enable or 'false' to disable
FEATURE_ORG_UNIT_WRITE_ENABLED=false
FEATURE_ORG_MEMBERSHIP_WRITE_ENABLED=false
FEATURE_HARD_DELETE_ENABLED=false
FEATURE_USER_WRITE_ENABLED=false
